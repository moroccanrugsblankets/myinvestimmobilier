# Protection du dossier uploads
# Autoriser uniquement les images, vidéos et PDF

Order Deny,Allow
Deny from all

<FilesMatch "\.(jpg|jpeg|png|webp|gif|pdf|mp4|mov|avi|webm)$">
    Allow from all
</FilesMatch>

# Empêcher l'exécution de scripts PHP
<FilesMatch "\.php$">
    Deny from all
</FilesMatch>
