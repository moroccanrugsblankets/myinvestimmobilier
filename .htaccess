Options -Indexes
RewriteEngine On

# ── Pass through real files and directories ───────────────────────────────────
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ── SEO-friendly public page URLs: /<slug> or /<slug>/ → page.php?slug=<slug> ─
RewriteRule ^([a-z0-9][a-z0-9\-]{0,98}[a-z0-9]?)/?$ /page.php?slug=$1 [L,QSA]
